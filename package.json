{
  "name": "dev-jai-nexus",
  "private": true,
  "packageManager": "pnpm@10.26.0",
  "scripts": {
    "dev": "pnpm -C portal dev",
    "build": "pnpm -C portal build",
    "start": "pnpm -C portal start",
    "lint": "pnpm -C portal lint",
    "seed": "pnpm -C portal db:seed",
    "db:seed": "pnpm -C portal db:seed",
    "prisma:generate": "pnpm -C portal prisma:generate",
    "prisma:migrate:local": "pnpm -C portal prisma:migrate:local",
    "prisma:studio:local": "pnpm -C portal prisma:studio:local",
    "typecheck": "pnpm -C portal typecheck",
    "dct:replay-check": "pnpm -C portal dct:replay-check",
    "dct:verify": "pnpm typecheck && pnpm dct:replay-check",
    "dct:extract": "pnpm -C portal dct:extract",
    "council:run": "node portal/scripts/council-run.mjs",
    "claude:bootstrap": "node portal/scripts/generate-claude-bootstrap.mjs",
    "code:pack": "node portal/scripts/generate-task-code-pack.mjs",
    "snapshot:motions": "node portal/scripts/snapshot-motion-full.mjs --manifest",
    "bootstrap:gen": "node portal/scripts/generate-bootstrap.mjs",
    "grid:ingest": "node portal/scripts/grid-ingest-bundle.mjs",
    "grid:review": "node portal/scripts/grid-review-motion-package.mjs",
    "grid:preflight": "node portal/scripts/grid-council-run-preconditions.mjs",
    "grid:vote-prep": "node portal/scripts/grid-vote-prep.mjs",
    "grid:launch": "node portal/scripts/grid-launch.mjs",
    "grid:status": "node portal/scripts/grid-status.mjs",
    "grid:operator": "node portal/scripts/grid-operator.mjs"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
